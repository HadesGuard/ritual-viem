{
  "name": "ritual-viem",
  "version": "0.1.0",
  "description": "Community viem extension for Ritual Chain: safe parsing of system transactions, async flow tracking (request -> commit -> settle -> delivery), and the Ritual protocol registry. Built by RitualScan.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "author": "RitualScan (https://ritualscan.hadesxbt.dev)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HadesGuard/ritual-viem.git"
  },
  "homepage": "https://github.com/HadesGuard/ritual-viem#readme",
  "bugs": {
    "url": "https://github.com/HadesGuard/ritual-viem/issues"
  },
  "keywords": [
    "ritual",
    "ritual-chain",
    "viem",
    "evm",
    "blockchain",
    "async-transactions",
    "precompiles",
    "web3"
  ],
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "chains": [
        "./dist/chains/index.d.ts"
      ],
      "protocol": [
        "./dist/protocol/index.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./chains": {
      "import": {
        "types": "./dist/chains/index.d.ts",
        "default": "./dist/chains/index.js"
      },
      "require": {
        "types": "./dist/chains/index.d.cts",
        "default": "./dist/chains/index.cjs"
      }
    },
    "./protocol": {
      "import": {
        "types": "./dist/protocol/index.d.ts",
        "default": "./dist/protocol/index.js"
      },
      "require": {
        "types": "./dist/protocol/index.d.cts",
        "default": "./dist/protocol/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:live": "RITUAL_LIVE=1 vitest run test/live.integration.test.ts",
    "lint:prose": "node scripts/lint-prose.mjs",
    "prepublishOnly": "npm run lint:prose && npm run typecheck && npm run test && npm run build"
  },
  "peerDependencies": {
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.4",
    "@types/node": "^22.20.0",
    "publint": "^0.2.12",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "viem": "^2.53.1",
    "vitest": "^2.1.8"
  }
}
